{
  "name": "efingplanner",
  "version": "1.0.0",
  "description": "A self-guided executive-function curriculum for kids (roughly ages 9-11) that teaches breaking down a big project by planning a real family trip to Japan. Markdown-only educational content; the tooling here only lints the docs.",
  "private": true,
  "scripts": {
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.pytest_cache\"",
    "lint:md:links": "remark . --quiet --frail --ignore-path .remarkignore",
    "lint:md:nested": "node .github/scripts/lint-nested-markdown.js",
    "test:toolchain-eol": "node --test tests/toolchain-eol/check-toolchain-eol.test.js"
  },
  "keywords": [
    "executive-function",
    "education",
    "curriculum",
    "open-educational-resources",
    "markdown"
  ],
  "author": "Frank Lesniak",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "glob": "^13.0.6",
    "jsonc-parser": "^3.3.1",
    "markdown-it": "^14.2.0",
    "markdownlint": "^0.41.0",
    "markdownlint-cli2": "^0.22.1",
    "remark-cli": "^12.0.1",
    "remark-validate-links": "^13.1.0",
    "semver": "^7.8.5",
    "yaml": "^2.9.0"
  }
}
